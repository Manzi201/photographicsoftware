{
  "expo": {
    "name": "Certificate System",
    "slug": "certificate-system",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1e3a8a"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e3a8a"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        { "photosPermission": "Allow Certificate System to access your photos." }
      ]
    ],
    "scheme": "certificate"
  }
}
